{
  "name": "asciidoctor-emoji",
  "version": "1.0.0",
  "description": "Asciidoctor Emoji Extension",
  "type": "module",
  "main": "./dist/asciidoctor-emoji.cjs",
  "browser": "./dist/browser/asciidoctor-emoji.js",
  "exports": {
    "browser": "./dist/browser/asciidoctor-emoji.js",
    "import": "./src/asciidoctor-emoji.js",
    "require": "./dist/asciidoctor-emoji.cjs"
  },
  "files": [
    "src",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "build": "rollup -c",
    "prepublishOnly": "npm run build",
    "update:twemoji-map": "node tasks/generate-twemoji-map.js"
  },
  "devDependencies": {
    "@asciidoctor/core": "~4.0",
    "@biomejs/biome": "2.5.5",
    "emoji-datasource": "16.0.0",
    "rollup": "4.62.2"
  },
  "peerDependencies": {
    "@asciidoctor/core": ">=4.0 <5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ggrossetie/asciidoctor-emoji.git"
  },
  "keywords": [
    "asciidoctor",
    "emoji",
    "javascript",
    "extension"
  ],
  "author": "Guillaume Grossetie (https://github.com/ggrossetie)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ggrossetie/asciidoctor-emoji/issues"
  },
  "homepage": "https://github.com/ggrossetie/asciidoctor-emoji#readme",
  "publishConfig": {
    "access": "public"
  },
  "volta": {
    "node": "24.18.0"
  }
}
